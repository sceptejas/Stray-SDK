# Stellar Agent Configuration
# Copy this file to .env and configure your values

# Required: Network Configuration
HORIZON_URL=https://horizon-testnet.stellar.org
NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Required: Your Stellar Account Credentials 
SOURCE_SECRET= #SCYHMQNU7xxxxxxx2SA3QQU2GA27JS6W47VL74JM45IDKDYVIELIRVQQ (Example - 56 chars starting with 'S')

# Optional: Account monitoring (if applicable)
MONITOR_ACCOUNT_ID= #GBBQHK5UU4xxxxxxxxW4H5ZKCUQRDG25AFJS2IKTAHSL7YPNW6QAU5HC (Example - 56 chars starting with 'G')
DESTINATION_ACCOUNT_ID=

# Balance Safety Settings
MINIMUM_BALANCE_XLM=1.0
BALANCE_CHECK_ENABLED=true

# Production Network Settings (Uncomment for mainnet)
# HORIZON_URL=https://horizon.stellar.org
# NETWORK_PASSPHRASE=Public Global Stellar Network ; September 2015
